          "name": "01 — Signup (new user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Signup returns success=true', () => {",
                  "  pm.expect(res.data.Signup.success).to.eql('true');",
                  "});",
                  "",
                  "pm.test('Signup returns a JWT token', () => {",
                  "  pm.expect(res.data.Signup.token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('signupToken', res.data.Signup.token);",
                  "});",
                  "",
                  "pm.test('User object has _id, username, email', () => {",
                  "  const u = res.data.Signup.user;",
                  "  pm.expect(u._id).to.be.a('string');",
                  "  pm.expect(u.username).to.eql('postman_user');",
                  "  pm.expect(u.email).to.eql('postman@test.com');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Signup($input: SignupInput!) {\n  Signup(input: $input) {\n    success\n    message\n    token\n    user {\n      _id\n      username\n      email\n    }\n  }\n}",
                "variables": "{\"input\":{\"username\":\"postman_user\",\"email\":\"postman@test.com\",\"password\":\"password123\"}}"
